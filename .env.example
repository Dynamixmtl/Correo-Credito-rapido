# Azure Table Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# Email SMTP (Office 365 - compte admin@dynamixmtl.com)
EMAIL_FROM=admin@dynamixmtl.com
EMAIL_PASSWORD=your-app-password-here

# Destinataire notification apres decision (institution gouvernementale)
NOTIFICATION_RECIPIENT=acostasalcedo.d@csdm.qc.ca

# URL publique de l'application (sans slash final)
NEXT_PUBLIC_APP_URL=https://credit-rapide.azurewebsites.net

# Cle secrete pour proteger l'endpoint de creation de demandes (appelee par Power Automate)
API_SECRET_KEY=change-this-to-a-strong-random-key

# Administration
ADMIN_USERNAME=admincr
ADMIN_PASSWORD=admincr
SESSION_SECRET=change-this-to-a-long-random-string
